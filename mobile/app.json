{
  "expo": {
    "name": "Fleet Driver",
    "slug": "fleet-driver-mobile",
    "scheme": "fleetdriver",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fullstackengineer.fleetdriver",
      "infoPlist": {
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "com.fullstackengineer.fleetdriver",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Necesitamos acceso a tu ubicacion para capturar la telemetria del conductor en tiempo real.",
          "locationAlwaysAndWhenInUsePermission": "Necesitamos ubicacion en segundo plano para seguir capturando la telemetria del conductor.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://127.0.0.1:4001"
    }
  }
}
